# Optional host port for the Ollama service in docker-compose.yml.
OLLAMA_HOST_PORT=12434

# Optional source path for compose.casa.yml builds.
LEAGUECLIPS_SOURCE_DIR=.

# Optional data root for compose.casa.yml runtime volumes.
CLIPSCREATOR_APPDATA_DIR=/DATA/AppData/ClipsCreator

# Optional T-shirt design frontend settings.
TSHIRT_FRONTEND_PORT=3002
TSHIRT_OLLAMA_MODEL=qwen2.5:7b-instruct
TSHIRT_OLLAMA_NUM_PREDICT=6500
TSHIRT_OLLAMA_TEMPERATURE=0.85
TSHIRT_GENERATE_INTERVAL_SECONDS=3600
TSHIRT_IMAGE_PROVIDER=local_diffusion
TSHIRT_LOCAL_IMAGE_SIZE=1024
TSHIRT_LOCAL_IMAGE_STEPS=28
TSHIRT_LOCAL_IMAGE_GUIDANCE_SCALE=7.0
TSHIRT_LOCAL_IMAGE_TIMEOUT_SECONDS=3600
TSHIRT_POLLINATIONS_API_KEY=
TSHIRT_POLLINATIONS_MODEL=flux
TSHIRT_IMAGE_SIZE=2048
TSHIRT_MAX_DESIGNS=80

# Optional local image-generation model settings.
IMAGEGEN_HOST_PORT=7860
IMAGEGEN_MODEL=stabilityai/stable-diffusion-xl-base-1.0
IMAGEGEN_DEVICE=auto
IMAGEGEN_DTYPE=auto
IMAGEGEN_WIDTH=1024
IMAGEGEN_HEIGHT=1024
IMAGEGEN_STEPS=28
IMAGEGEN_GUIDANCE_SCALE=7.0
IMAGEGEN_MODEL_CPU_OFFLOAD=true
